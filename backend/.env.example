# ── Application ─────────────────────────────────────────
APP_NAME="Marjon"
DEBUG=true

# ── Security ────────────────────────────────────────────
# REQUIRED in production (DEBUG=false). Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Database ────────────────────────────────────────────
# Local dev (SQLite):
DATABASE_URL=sqlite+aiosqlite:///./app.db
# Production (Postgres/Supabase):
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname
# Optional sync URL used by Alembic migrations:
# MIGRATION_DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Redis ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── CORS ────────────────────────────────────────────────
# JSON array of allowed origins
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]
