# ── Database ──────────────────────────────────────────────────
# Local Docker (docker-compose):
DATABASE_URL=postgresql+asyncpg://marjon:marjon_secret@localhost:5432/marjon

# Neon (remote, SSL auto-enabled):
# DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# SQLite fallback (dev only):
# DATABASE_URL=sqlite+aiosqlite:///./app.db

# ── Security ─────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-string-at-least-32-chars
DEBUG=true

# ── Server ───────────────────────────────────────────────────
# PORT=8000  # Render sets this automatically

# ── Redis (optional) ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── CORS ─────────────────────────────────────────────────────
# Add your Vercel frontend URL here:
# ALLOWED_ORIGINS=["http://localhost:5173","https://marjon.vercel.app"]

# ── Интеграции главной админки (опционально) ─────────────────
# DEVENT_BASE_URL=https://devent.example.com/api
# DEVENT_API_KEY=secret
